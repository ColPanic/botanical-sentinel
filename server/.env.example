# Copy to .env and fill in values. .env is gitignored.

# Database
DB_PASSWORD=changeme
DB_URL=postgresql://botanical:changeme@localhost:5432/botanical

# MQTT (use localhost when running services outside Docker)
MQTT_HOST=localhost
MQTT_PORT=1883

# Web dashboard — set to the public IP/hostname of this server
PUBLIC_API_URL=http://192.168.4.128:8000
ORIGIN=http://192.168.4.128:3000
# Restrict CORS to the web app origin. Defaults to * (allow all) if unset.
CORS_ORIGIN=http://192.168.4.128:3000
