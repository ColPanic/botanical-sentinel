# URL of the FastAPI backend, reachable from the browser (and the SSR server).
# In production set this to the public IP/hostname of your edge server.
# In dev (Vite), leave unset — the dev-server proxy handles it automatically.
PUBLIC_API_URL=http://192.168.4.128:8000

# Required by adapter-node in production to prevent CSRF. Set to the public URL of the web app.
ORIGIN=http://192.168.4.128:3000
